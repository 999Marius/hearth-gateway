# Copy to .env and fill in values
# NEVER commit .env to git

# App
APP_ENV=development
SECRET_KEY=change-me-to-a-random-64-char-hex-string
APP_HOST=0.0.0.0
APP_PORT=8000

# Database
DATABASE_URL=sqlite:///./data/hearth.db

# JWT
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Pi-hole (read-only path inside container)
PIHOLE_FTL_DB=/etc/pihole/pihole-FTL.db

# WireGuard
WG_INTERFACE=wg0
WG_CONFIG_PATH=/etc/wireguard/wg0.conf
WG_SERVER_PORT=51820
WG_SERVER_ENDPOINT=your-public-ip-or-domain

# Admin seed (first run only)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@hearth.local
ADMIN_PASSWORD=change-me-on-first-run

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://hearth.local
